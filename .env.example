# RELAY — environment variables (copy to .env.local for the frontend, and export
# the backend ones in the shell that runs each service). Never commit real keys.

# ── Frontend (.env.local) ─────────────────────────────────────────────────────
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_MAPBOX_TOKEN=your_token_here
NEXT_PUBLIC_WS_URL=ws://localhost:8080
BRAIN_API_URL=http://localhost:3001
MATCHMAKER_API_URL=http://localhost:3002

# ── Brain (brain/, port 3001) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Shared Redis Stack instance (session memory + vector search). Defaults to this
# if unset, so `docker compose up -d redis` is enough for local dev.
REDIS_URL=redis://localhost:6379
# Trained urgency classifier the Brain consults (max-severity merge). Optional —
# if unreachable the Brain keeps Claude's priority. Set CLASSIFIER_ENABLED=false
# to skip the call entirely.
CLASSIFIER_URL=http://localhost:8000
# CLASSIFIER_ENABLED=true

# ── Matchmaker (matchmaker/, port 3002) ───────────────────────────────────────
# Uses the same REDIS_URL above for the resource vector index.
# MATCHMAKER_PORT=3002

# ── Classifier (classifier/, port 8000) ───────────────────────────────────────
# CLASSIFIER_PORT=8000   # change if 8000 is taken; match CLASSIFIER_URL above
