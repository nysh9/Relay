  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mapbox-gl": "^3.4.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8",
    "tailwindcss": "^4",
    "typescript": "^5"
